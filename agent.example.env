# ─────────────────────────────────────────────────────────────────────────────
# Single-Brain agent config — copy to `agent.env`, fill in, then:
#     ./new-agent.sh agent.env
# This one file defines a whole agent. It becomes the deployed `.env`, and
# new-agent.sh also renders hermes/data/config.yaml from the __PLACEHOLDER__ values.
#
# ⚠  Secrets live here. This file is gitignored. Never commit a filled-in copy.
# ─────────────────────────────────────────────────────────────────────────────

# ── Identity / infra ─────────────────────────────────────────────────────────
AGENT_NAME=my-agent                 # container + network name; [a-z0-9-]
BASE_DIR=/srv/my-agent              # host dir that holds data/vault/logs/bin
HERMES_PORT=18789                   # localhost UI port (SSH-tunnel or `tailscale serve`)
TZ=America/New_York
AGENT_PERSONA=technical             # config display.personality: technical | concise | helpful | kawaii | ...

# Home channels the agent posts to proactively (optional; leave blank to skip).
TELEGRAM_HOME_CHANNEL=
SLACK_HOME_CHANNEL=

# ── Inference (primary = Fireworks, fallback = Together) ──────────────────────
# Get keys: https://fireworks.ai/account/api-keys  +  https://api.together.ai/settings/api-keys
FIREWORKS_API_KEY=fw_REPLACE_ME             # PRIMARY (required)
TOGETHER_API_KEY=tgp_v1_REPLACE_ME          # fallback (recommended)
OPENROUTER_API_KEY=                         # optional extra fallback

# ── Channels (provide tokens for the channels enabled in the config) ─────────
# Slack: app with Socket Mode (xoxb- bot + xapp- app). Telegram: @BotFather token.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
GATEWAY_ALLOW_ALL_USERS=false        # true = anyone can DM the bot (use allowlists otherwise)

# ── Obsidian/Notion memory mirror (only needed for `--profile sync`) ─────────
# Run `NOTION_TOKEN=... NOTION_PARENT_PAGE=... python3 sync/create_notion_dbs.py`
# once to create the 5 DBs, then paste the printed IDs below.
NOTION_TOKEN=
NOTION_PARENT_PAGE=                  # page ID the integration can write to (for create_notion_dbs.py)
NOTION_DB_SESSIONS=
NOTION_DB_KANBAN_TASKS=
NOTION_DB_MEMORIES=
NOTION_DB_SKILLS=
NOTION_DB_EVENTS=
SYNC_INTERVAL_SECONDS=60

# ── Resource caps (optional) ─────────────────────────────────────────────────
HERMES_MEM_LIMIT=2g
HERMES_CPUS=2.0
